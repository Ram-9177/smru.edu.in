# ----------------------------------------------------------------------
# 🔧 Stmarys Deployment: Ultimate Stability Config
# ----------------------------------------------------------------------

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 1. Force HTTPS and non-WWW (Canonical Domain smru.edu.in)
    # This prevents 'Link-Access' errors and SSL warnings
    RewriteCond %{HTTPS} off [OR]
    RewriteCond %{HTTP_HOST} ^www\. [NC]
    RewriteRule ^(.*)$ https://smru.edu.in/$1 [L,R=301]

    # 1b. Retired law URLs
    RewriteRule ^schools/law/legal-studies/llb-general/?$ https://smru.edu.in/schools/law/ [L,R=301]
    RewriteRule ^llm/?$ https://smru.edu.in/schools/law/ [L,R=301]
    RewriteRule ^phd-law/?$ https://smru.edu.in/schools/law/ [L,R=301]

    # 2. Maintenance Mode Switch (OFF)
</IfModule>

# SEO/security headers for the static export.
# HSTS is sent on all responses, including www/non-www redirects, so HTTPS-only
# behavior is visible to browsers and crawlers after the first secure request.
<IfModule mod_setenvif.c>
    SetEnvIf Request_URI "^/(developer|api)(/|$)" STMARYS_PRIVATE_NOINDEX=1
    SetEnvIf Request_URI "^/thank-you(/|$)" STMARYS_THANKYOU_NOINDEX=1
</IfModule>

<IfModule mod_headers.c>
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Keep private utility routes out of the index at the HTTP header layer.
    # Public compliance routes, including /mandatory-disclosure/, are not matched here.
    Header always set X-Robots-Tag "noindex, nofollow" env=STMARYS_PRIVATE_NOINDEX
    Header always set X-Robots-Tag "noindex, follow" env=STMARYS_THANKYOU_NOINDEX
</IfModule>

# Caching Policy
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    ExpiresByType text/html "access plus 0 seconds"
    ExpiresByType image/webp "access plus 1 year"
</IfModule>

AddType image/webp .webp

# Block sensitive files
<FilesMatch "(\.env|\.pkg|package\.json|package-lock\.json|vite\.config\.js|tailwind\.config\.js)$">
    Order deny,allow
    Deny from all
</FilesMatch>

